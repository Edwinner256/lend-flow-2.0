# LendFlow Environment Variables (example — safe to commit)
# Copy to .env and fill in your values

# Secret key for session signing (generate a random one)
SECRET_KEY=change-this-to-a-random-string

# Flask environment
FLASK_ENV=production

# SMS: set to True to skip real SMS sending
SMS_MOCK_MODE=False

# Database — SQLite (local dev) or PostgreSQL (production)
# ─────────────────────────────────────────────────────
# Local dev: leave unset → uses SQLite at data/lendflow.db
# DATABASE_PATH=/app/data/lendflow.db  # Railway: mount a volume
#
# Production (Vercel / Railway): set DATABASE_URL to a PostgreSQL connection string
# DATABASE_URL=postgresql://user:pass@host:5432/lendflow

# AI: optional OpenAI API key for enhanced AI (GPT-powered responses)
# Leave blank to use the built-in rule engine (no external dependency)
# OPENAI_API_KEY=sk-your-key-here
