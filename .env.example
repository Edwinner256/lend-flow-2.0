# LendFlow Environment Variables (example — safe to commit)
# Copy to .env and fill in your values

# Secret key for session signing (generate a random one)
SECRET_KEY=change-this-to-a-random-string

# Flask environment
FLASK_ENV=production

# SMS: set to True to skip real SMS sending
SMS_MOCK_MODE=False

# Database path (default: data/lendflow.db)
# On Railway: mount a volume at /app/data — path auto-resolves
# DATABASE_PATH=/app/data/lendflow.db
