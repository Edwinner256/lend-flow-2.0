{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "VERCEL": "1",
    "FLASK_ENV": "production",
    "SMS_MOCK_MODE": "True"
  },
  "buildCommand": "pip install -r requirements.txt"
}
